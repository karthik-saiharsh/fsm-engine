{
  "name": "fsm-monorepo",
  "version": "3.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    ".{ts,js}": "eslint — cache — fix",
    ".{ts,js,css,md}": "prettier — write",
    ".js": "eslint — cache — fix",
    ".{js,css,md}": "prettier — write"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . — fix && prettier — write .",
    "prepare": "lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0"
  }
}